# Exness AI Trading Bot - Configuration
# Copy this file to .env and fill in your credentials

# --- Exness / MetaTrader ---
# Option 1: Direct MT5 (Windows VPS with MT5 installed)
EXNESS_LOGIN=
EXNESS_PASSWORD=
EXNESS_SERVER=

# Option 2: MetaAPI (cloud-based, works on any platform)
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
# Set to "true" to use MetaAPI instead of direct MT5
USE_METAAPI=true

# --- AI / LLM ---
ANTHROPIC_API_KEY=

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database (optional) ---
# Leave empty to use SQLite
DATABASE_URL=
